# Secrets and environment
.env

# Certificate bundles / keys are environment-specific and sensitive
*.pem
*.key
ca-bundle.pem
certs/

# Isolated Claude Code config holds OAuth credentials — never commit
.claude-config/

# Records which config dir cc uses (may be a personal absolute path)
.cc-config-dir

# Unix domain sockets (cc's proxy socket lives under ~/.cc, but never commit one)
*.sock

# Logs
*.log
proxy.log
proxy-stdout.log

# Node
node_modules/
