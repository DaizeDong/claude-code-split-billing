# Copy this file to .env and fill in your values. .env is gitignored — never commit secrets.
#
# cc runs a local Bun proxy on a private per-user AF_UNIX socket. There is no port,
# no hosts-file change, and no certificate — plain `claude` is completely unaffected.
# The socket path is chosen by cc (default: ~/.cc/cc.sock); override with the CC_SOCK
# environment variable, not here.

# ---- Gateway (your Anthropic-compatible inference endpoint) ----
# Hostname of the gateway that inference is billed to. REQUIRED.
GATEWAY_HOST=<YOUR_GATEWAY_HOST>
# TLS port of the gateway (almost always 443). Leave 443 unless yours differs.
GATEWAY_PORT=443
# Path prefix prepended before /v1/messages. Leave empty if the gateway serves
# the Anthropic API at the root. Example value: /some-prefix
GATEWAY_BASE_PATH=

# Headers to inject on inference requests, as a JSON object. Put whatever your
# gateway requires for auth / identity here. This is where your secret key goes.
# Examples (pick what your gateway needs):
#   GATEWAY_HEADERS={"Authorization":"Bearer <TOKEN>"}
#   GATEWAY_HEADERS={"X-Api-Key":"<KEY>"}
#   GATEWAY_HEADERS={"<AUTH_HEADER_NAME>":"<KEY>","<USER_HEADER_NAME>":"<USER_ID>"}
GATEWAY_HEADERS={"<AUTH_HEADER_NAME>":"<KEY>"}

# Client headers to strip before forwarding inference upstream (comma-separated).
# In socket mode Claude Code sends no auth of its own, but keep this as a safety net.
GATEWAY_STRIP_HEADERS=authorization,x-api-key

# Optional model remapping. JSON of { "<substring>": "<replacement model id>" }.
# The incoming model id is lowercased; the first key that is a substring of it
# replaces the whole model id. Needed if your gateway rejects the model ids Claude
# Code sends. NOTE: recent Claude Code defaults to a "fable" model — include a
# mapping for it or the gateway will reject the request.
#   GATEWAY_MODEL_MAP={"fable":"<gateway-top-id>","haiku":"<gateway-haiku-id>","sonnet":"<gateway-sonnet-id>","opus":"<gateway-opus-id>"}
GATEWAY_MODEL_MAP=
# Fallback model id used only when a request has no/invalid model field. Optional.
GATEWAY_DEFAULT_MODEL=

# ---- Control plane ----
# Where Claude Code's non-inference traffic (OAuth, Remote Control, feature flags) is
# sent by the proxy. The proxy injects your OAuth bearer (read fresh from
# $CLAUDE_CONFIG_DIR/.credentials.json) on these requests. Leave as the default.
CONTROL_HOST=api.anthropic.com
