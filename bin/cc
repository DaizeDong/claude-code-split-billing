#!/usr/bin/env bash
# Claude Code via a custom inference gateway, with Remote Control still working.
# Isolated config + local rerouting proxy + (optional) corporate CA trust.
# All args are forwarded to claude, e.g.:  cc --resume   |   cc --dangerously-skip-permissions
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

# --- resolve a Node.js >= 18 for the local proxy ---
# Claude Code bundles its own runtime; this is only for src/proxy.js + ensure-proxy.js.
# Override by exporting NODE_BIN=/path/to/node (useful when the default `node` is too old,
# e.g. a system/conda Node 12). Otherwise we try `node` then common install locations.
node_major() { "$1" -e 'process.stdout.write(process.versions.node.split(".")[0])' 2>/dev/null; }
resolve_node() {
  local c m
  for c in ${NODE_BIN:+"$NODE_BIN"} node \
           "$HOME"/.nvm/versions/node/*/bin/node \
           /usr/local/bin/node /opt/homebrew/bin/node /usr/bin/node; do
    command -v "$c" >/dev/null 2>&1 || [ -x "$c" ] || continue
    m="$(node_major "$c")" || continue
    if [ -n "$m" ] && [ "$m" -ge 18 ] 2>/dev/null; then printf '%s' "$c"; return 0; fi
  done
  return 1
}
if ! NODE_BIN="$(resolve_node)"; then
  echo "cc: need Node.js >= 18 to run the local proxy." >&2
  echo "    Install Node >= 18, or export NODE_BIN=/path/to/node and retry." >&2
  exit 1
fi

# --- config dir ---
# setup-config.sh records the chosen dir in .cc-config-dir: an isolated dir by default, or
# your real ~/.claude in --inherit mode (shared login/plugins/skills/sessions/MCP/settings).
# An explicit CLAUDE_CONFIG_DIR in the environment always wins.
if [ -z "${CLAUDE_CONFIG_DIR:-}" ]; then
  if [ -f "$REPO_ROOT/.cc-config-dir" ]; then
    CLAUDE_CONFIG_DIR="$(cat "$REPO_ROOT/.cc-config-dir")"
  else
    CLAUDE_CONFIG_DIR="$REPO_ROOT/.claude-config"
  fi
fi
export CLAUDE_CONFIG_DIR

# --- ensure OAuth auth (an api key/token would disable Remote Control) ---
unset ANTHROPIC_API_KEY ANTHROPIC_AUTH_TOKEN ANTHROPIC_CUSTOM_HEADERS \
      ANTHROPIC_MODEL ANTHROPIC_DEFAULT_OPUS_MODEL ANTHROPIC_DEFAULT_SONNET_MODEL \
      ANTHROPIC_DEFAULT_HAIKU_MODEL 2>/dev/null || true

# --- inference -> local proxy -> gateway ---
PROXY_PORT="${PROXY_PORT:-8787}"
export ANTHROPIC_BASE_URL="http://127.0.0.1:${PROXY_PORT}"

# --- trust corporate TLS root so Node reaches the control plane (only if bundle exists) ---
if [ -f "$REPO_ROOT/ca-bundle.pem" ]; then
  export NODE_EXTRA_CA_CERTS="$REPO_ROOT/ca-bundle.pem"
fi

# --- make sure the rerouting proxy is running; start it if not ---
# ensure-proxy.js spawns proxy.js via process.execPath, so it inherits this same Node.
"$NODE_BIN" "$REPO_ROOT/src/ensure-proxy.js"

# --- launch claude with all passed-through args (RC on by default via settings.json) ---
exec claude "$@"
