#!/usr/bin/env bash
# Claude Code via a custom inference gateway, with Remote Control still working -
# isolated so plain `claude` is unaffected. Inference is billed to your gateway; the
# account/OAuth control plane (incl. Remote Control) still talks to real Anthropic.
# All args are forwarded to claude, e.g.:  cc --resume   |   cc --dangerously-skip-permissions
set -euo pipefail

# Resolve symlinks so this works when cc is symlinked onto PATH (the recommended install).
SOURCE="${BASH_SOURCE[0]}"
while [ -h "$SOURCE" ]; do
  DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  case "$SOURCE" in /*) ;; *) SOURCE="$DIR/$SOURCE" ;; esac
done
SCRIPT_DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

# --- Bun is required: Claude Code's ANTHROPIC_UNIX_SOCKET transport uses Bun's
#     fetch({unix}) over an AF_UNIX socket, so the proxy runs under Bun. ---
if ! command -v bun >/dev/null 2>&1; then
  echo "cc: Bun is required for the local proxy. Install it once, then retry:" >&2
  echo "       npm i -g bun      (or: curl -fsSL https://bun.sh/install | bash)" >&2
  exit 1
fi

# --- config dir: inherit your real ~/.claude by default so Remote Control can read
#     your stored OAuth login. Pointer written by setup-config; env var always wins. ---
if [ -z "${CLAUDE_CONFIG_DIR:-}" ]; then
  if [ -f "$REPO_ROOT/.cc-config-dir" ]; then
    CLAUDE_CONFIG_DIR="$(cat "$REPO_ROOT/.cc-config-dir")"
  else
    CLAUDE_CONFIG_DIR="$HOME/.claude"
  fi
fi
export CLAUDE_CONFIG_DIR

# --- clear API-key style auth (would change auth mode / disable Remote Control) ---
unset ANTHROPIC_API_KEY ANTHROPIC_AUTH_TOKEN ANTHROPIC_CUSTOM_HEADERS \
      ANTHROPIC_MODEL ANTHROPIC_DEFAULT_OPUS_MODEL ANTHROPIC_DEFAULT_SONNET_MODEL \
      ANTHROPIC_DEFAULT_HAIKU_MODEL 2>/dev/null || true

# --- short socket path (AF_UNIX sun_path is ~108 chars). Override with CC_SOCK. ---
: "${CC_SOCK:=$HOME/.cc/cc.sock}"
mkdir -p "$(dirname "$CC_SOCK")"

# --- socket mode: turns Remote Control on (bypasses the host check) AND sends all API
#     traffic over the socket to our proxy. http:// => plain HTTP on the socket, so no
#     TLS and no certificate are needed. ---
export ANTHROPIC_UNIX_SOCKET="$CC_SOCK"
export ANTHROPIC_BASE_URL="http://api.anthropic.com"

# --- the inference SDK in socket mode needs an OAuth token present to resolve an auth
#     method. It is NOT sent upstream (the proxy authenticates); it's a local marker. ---
CLAUDE_CODE_OAUTH_TOKEN="$(bun "$REPO_ROOT/src/read-oauth.js")"
if [ -z "$CLAUDE_CODE_OAUTH_TOKEN" ]; then
  echo "cc: no Claude OAuth login found in $CLAUDE_CONFIG_DIR." >&2
  echo "    Sign in once with plain  claude  (run /login), then retry cc." >&2
  exit 1
fi
export CLAUDE_CODE_OAUTH_TOKEN
export CLAUDE_CODE_OAUTH_SCOPES="$(bun "$REPO_ROOT/src/read-oauth.js" scopes)"

# --- make sure the rerouting proxy is running; start it if not ---
bun "$REPO_ROOT/src/ensure-proxy.js"

# --- launch claude with all passed-through args (RC on by default via settings.json) ---
exec claude "$@"
